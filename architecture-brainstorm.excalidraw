    {
      "id": "nfsbUPtUOzxElxljosvk1",
      "type": "text",
      "x": 245,
      "y": 125,
      "width": 665.6195678710938,
      "height": 450,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
